# Copy this file to `.env.local` and fill in real keys. `.env.local` is gitignored.

# Firecrawl — https://firecrawl.dev  (SearchProvider — see src/lib/evidence/firecrawl.ts)
# Currently the sole provider (SEARCH_PROVIDER in evidence/config.ts). Once the search/scrape
# split lands (docs/search-scrape-provider-split-spec.md), this becomes the default SCRAPE
# provider — set it regardless of which provider does search.
FIRECRAWL_API_KEY=fc-...

# Exa — https://dashboard.exa.ai/api-keys  (SearchProvider — see src/lib/evidence/exa.ts)
# Set SEARCH_PROVIDER="exa" in evidence/config.ts to use it today. Once the search/scrape split
# lands (docs/search-scrape-provider-split-spec.md), this becomes the default SEARCH provider —
# set it alongside FIRECRAWL_API_KEY, not instead of it.
EXA_API_KEY=...

# OpenAI — https://platform.openai.com  (used for the inference / scoring step)
OPENAI_API_KEY=sk-...

# Google — https://aistudio.google.com/apikey  (Gemini 3.1 Flash-Lite — the skeptic role, see
# src/lib/roles.ts)
GOOGLE_GENERATIVE_AI_API_KEY=...

# Supabase — https://supabase.com  (caching, blocklist, leaderboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Anthropic — https://www.anthropic.com  (used for the inference / scoring step)
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults shown). Only set if you want to change behavior.
# OPENAI_MODEL=gpt-4o                   # analysis model
# SCAN_TRIAGE_MODEL=gpt-4o-mini         # model for intent adaptation + triage scoring
# SCAN_INTENTS=10                        # number of search intents to generate
# SCAN_RESULTS_PER_INTENT=8             # search results requested per intent
# SCAN_MAX_SCRAPE=28                     # max pages to scrape after triage
# SCAN_QUOTA_FLOOR=2                     # min sources per intent before merit fill
